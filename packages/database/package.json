{
  "name": "@qorvex/database",
  "version": "0.1.0",
  "private": true,
  "type": "commonjs",
  "main": "./generated/client/index.js",
  "types": "./generated/client/index.d.ts",
  "exports": {
    ".": {
      "types": "./generated/client/index.d.ts",
      "default": "./generated/client/index.js"
    }
  },
  "scripts": {
    "generate": "dotenv -e ../../.env -- prisma generate --schema prisma/schema.prisma",
    "migrate": "dotenv -e ../../.env -- prisma migrate dev --schema prisma/schema.prisma",
    "migrate:deploy": "dotenv -e ../../.env -- prisma migrate deploy --schema prisma/schema.prisma",
    "seed": "dotenv -e ../../.env -- tsx prisma/seed.ts",
    "studio": "dotenv -e ../../.env -- prisma studio --schema prisma/schema.prisma",
    "lint": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@prisma/client": "^6.9.0",
    "bcryptjs": "^3.0.3"
  },
  "devDependencies": {
    "@types/node": "^24.0.3",
    "dotenv-cli": "^8.0.0",
    "prisma": "^6.9.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
