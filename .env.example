# Local Docker PostgreSQL defaults. Replace when targeting Supabase.
DATABASE_URL="postgresql://corestack:corestack@localhost:5432/corestack?schema=public"
DIRECT_URL="postgresql://corestack:corestack@localhost:5432/corestack?schema=public"

# Supabase PostgreSQL placeholders for temporary managed DB usage.
# Encode special characters in the password, for example @ becomes %40.
# DATABASE_URL="postgresql://postgres.ofiajrknxhtquctgrysr:YOUR_URL_ENCODED_PASSWORD@aws-1-us-east-2.pooler.supabase.com:6543/postgres?pgbouncer=true&sslmode=require"
# DIRECT_URL="postgresql://postgres.ofiajrknxhtquctgrysr:YOUR_URL_ENCODED_PASSWORD@aws-1-us-east-2.pooler.supabase.com:5432/postgres?sslmode=require"

# Local Docker compose values.
POSTGRES_USER="corestack"
POSTGRES_PASSWORD="corestack"
POSTGRES_DB="corestack"

# Backend auth. Never use Supabase JWT secret here. Production requires a unique
# value of at least 32 characters and refuses placeholders.
# Generate one with: node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_SECRET="replace-with-corestack-secret"
JWT_EXPIRES_IN="8h"

# API / CORS.
API_PORT=4000
CORS_ORIGIN="http://localhost:3000,https://YOUR_FRONTEND_VERCEL_URL"
TRUST_PROXY=1
API_RATE_LIMIT_WINDOW_MS=900000
API_RATE_LIMIT_MAX=600
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=10
API_JSON_BODY_LIMIT="1mb"
API_FORM_BODY_LIMIT="1mb"

# Internal-only access control. Empty means no application-level IP restriction.
# Enforce the same policy at Vercel Firewall/Zero Trust in production.
# Use office/VPN static IPs or CIDR ranges, for example: "203.0.113.10,198.51.100.0/24"
INTERNAL_ALLOWED_IPS=""

# Frontend.
NEXT_PUBLIC_API_URL="http://localhost:4000"

# Backend-only Supabase values. Never expose these with NEXT_PUBLIC_.
SUPABASE_URL="https://ofiajrknxhtquctgrysr.supabase.co"
# Prefer SUPABASE_SERVICE_ROLE_KEY for Storage uploads. SUPABASE_SECRET_KEY is also supported.
SUPABASE_SERVICE_ROLE_KEY="replace-with-service-role-key"
SUPABASE_SECRET_KEY="replace-with-secret-key"
SUPABASE_JWKS_URL="https://ofiajrknxhtquctgrysr.supabase.co/auth/v1/.well-known/jwks.json"
SUPABASE_PRODUCT_IMAGE_BUCKET="product-images"
