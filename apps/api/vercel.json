{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "functions": {
    "api/index.ts": {
      "includeFiles": [
        "node_modules/@qorvex/database/**",
        "../../packages/database/dist/**",
        "../../packages/database/generated/client/**",
        "../../packages/database/package.json"
      ]
    }
  },
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/api/index.ts"
    }
  ]
}
